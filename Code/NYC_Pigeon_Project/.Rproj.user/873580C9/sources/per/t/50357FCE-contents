#### // This project will analyze spatial patterns of pigeon activity at New York City subway station entrances. Using wildlife observation data combined with MTA entrance locations the study will identify pigeon hotspots associated with increased pigeon presence.//


#
# Load Libraries ----
#

library(sf) ## spatial data (vector)

#
# Read Data ----
#
pigeon_311_dl <- st_read("../../Data/Raw/pigeon_311_unsanitary.gpkg")

# Check columns and data types
glimpse(pigeon_311_dl)

# Reorder columns
pigeon_311 <- pigeon_311_dl[, c(
  "unique_key",
  "created_date",
  "complaint_type",
  "descriptor",
  "incident_address",
  "city",
  "latitude",
  "longitude",
  "geom"
)]

# Convert latitude and longitude to numeric
pigeon_311$latitude  <- as.numeric(pigeon_311$latitude)
pigeon_311$longitude <- as.numeric(pigeon_311$longitude)

# Make sure geom is the active geometry column
pigeon_311 <- st_set_geometry(pigeon_311, "geom")

# Remove empty geometry
pigeon_311 <- pigeon_311[!st_is_empty(pigeon_311), ]

# Write out a new GeoPackage
out_gpkg <- "../../Data/Cleaned/pigeon_311_unsanitary_preprocessed.gpkg"


st_write(
  pigeon_311,
  dsn = out_gpkg,
  layer = "pigeon_311_unsanitary_preprocessed",
  delete_dsn = TRUE
)

# Quick confirmation
st_layers(out_gpkg)

